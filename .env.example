# ─── MealTrace Digital — Environment Variables Template ───
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.

# Firebase
FIREBASE_KEY_PATH=serviceAccountKey.json

# JWT Signing — Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# QR Code Signing — Generate with: python -c "import secrets; print(secrets.token_hex(32))"
QR_SIGNING_SECRET=

# Razorpay — Get from https://dashboard.razorpay.com/
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXX
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# App Config
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
