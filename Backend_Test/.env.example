BASE_URL=http://localhost:8000
GEMINI_API_KEY=your_gemini_api_key_here

# Dev login bypass (must be enabled on the backend to auto-create test users)
DEV_LOGIN_ENABLED=true

# ── Dynamic Test IDs (OPTIONAL — auto-resolved at runtime) ──────────────────
# These are populated automatically by conftest.py by calling POST /admin/residents
# and POST /admin/vendors at session start, capturing the Firebase UIDs returned.
# You do NOT need to fill these in manually. They are included below only as a
# reference or for debugging if you want to pin specific existing IDs.
TEST_RESIDENT_ID=
TEST_VENDOR_ID=
TEST_ADMIN_ID=
TEST_SITE_ID=
TEST_PLAN_ID=
